<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Scan Food</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<!-- ZXing library -->
<script src="https://unpkg.com/@zxing/library@latest"></script>

<style>
body {
    margin: 0;
    background: #0d1117;
    font-family: Arial, sans-serif;
    color: white;
    text-align: center;
}

/* TOP MENU */
#topMenu {
    display: flex;
    justify-content: space-around;
    background: #1a1f27;
    padding: 14px;
    border-bottom: 2px solid #222;
}
#topMenu a {
    color: #ccc;
    text-decoration: none;
    font-weight: bold;
}
#topMenu a.active {
    color: #00e676;
}

/* HEADERS */
h1 {
    margin-top: 20px;
    font-size: 28px;
    color: #42a5f5;
}

/* DAILY COUNTER */
#dailyCounter {
    margin-top: 5px;
    font-size: 16px;
    color: #cccccc;
}

/* CAMERA PREVIEW */
#cameraPreview {
    width: 92%;
    height: 260px;
    background: #111820;
    border: 3px solid #42a5f5;
    border-radius: 14px;
    margin: 20px auto;
    display: none;
    transition: 0.3s;
}

/* BUTTONS */
.scan-btn {
    width: 92%;
    padding: 16px;
    margin: 10px auto;
    background: #42a5f5;
    color: white;
    font-size: 18px;
    border: none;
    border-radius: 12px;
    box-shadow: 0 0 15px #42a5f5aa;
    transition: 0.3s;
    display: block;
}
.scan-btn:hover {
    box-shadow: 0 0 25px #42a5f5ff;
    transform: scale(1.03);
}

/* NUTRITION CARD */
.nutrition-card {
    width: 92%;
    background: #111820;
    border-radius: 18px;
    padding: 20px;
    margin: 20px auto;
    box-shadow: 0 0 25px #42a5f566;
    display: none;
    text-align: left;
}

/* CARD HEADER */
.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.product-image {
    width: 120px;
    height: 120px;
    border-radius: 14px;
    object-fit: cover;
    background: #222;
}
.cal-box {
    background: #42a5f5;
    color: white;
    padding: 12px 16px;
    border-radius: 14px;
    text-align: center;
    box-shadow: 0 0 12px #42a5f5aa;
}
.cal-box span {
    font-size: 24px;
    font-weight: bold;
}

/* HEALTH SCORE */
.health-row {
    width: 92%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    margin-top: 12px;
    gap: 12px;
}
.health-gauge {
    width: 75px;
    height: 75px;
    border-radius: 50%;
    border: 6px solid #4caf50;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 18px;
    color: white;
    box-shadow: 0 0 12px #4caf50aa;
}

/* NUTRITION TABLE */
.nutri-table {
    width: 92%;
    margin: 15px auto;
    background: #0f141a;
    padding: 15px;
    border-radius: 12px;
}
.nutri-table div {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    border-bottom: 1px solid #222;
}
.nutri-table div:last-child {
    border-bottom: none;
}

/* TRAFFIC LIGHTS */
.traffic {
    font-weight: bold;
    padding: 4px 10px;
    border-radius: 8px;
    font-size: 13px;
    min-width: 80px;
    text-align: center;
    color: #ffffff;
}
.red { background:#ff5252; }
.orange { background:#ffb74d; }
.green { background:#66bb6a; }

/* MACRO BARS */
.macro-section {
    width: 92%;
    margin: 15px auto;
}
.macro-row {
    margin-bottom: 10px;
}
.macro-label {
    font-size: 14px;
    margin-bottom: 4px;
}
.macro-bar {
    width: 100%;
    height: 10px;
    background: #1a222c;
    border-radius: 10px;
    overflow: hidden;
}
.macro-fill {
    height: 100%;
    border-radius: 10px;
}
.macro-protein { background: #42a5f5; }
.macro-carbs   { background: #ffca28; }
.macro-fat     { background: #ef5350; }

/* RATING */
.rating {
    font-size: 22px;
    font-weight: bold;
    margin-top: 10px;
}
.good { color: #7ed957; }
.ok   { color: #f5d142; }
.bad  { color: #ff5252; }

/* WARNINGS */
.reason {
    margin-top: 10px;
    font-size: 15px;
    color: #ffb3b3;
    font-weight: bold;
}

/* ADD BUTTON */
.add-btn {
    width: 92%;
    margin: 20px auto;
    padding: 16px;
    background: #00c853;
    color: white;
    font-size: 18px;
    border: none;
    border-radius: 12px;
    box-shadow: 0 0 15px #00c853aa;
}

/* FLASH EFFECTS */
.flash-red {
    animation: flashRed 1.5s ease;
}
.flash-green {
    animation: flashGreen 1.5s ease;
}
@keyframes flashGreen {
    0% { background-color: #004d00; }
    100% { background-color: #0d1117; }
}
@keyframes flashRed {
    0% { background-color: #4d0000; }
    100% { background-color: #0d1117; }
}
</style>
</head>
<body>

<div id="topMenu">
    <a href="index.html">Home</a>
    <a href="scan.html" class="active">Scan</a>
    <a href="weeks.html">Weeks</a>
    <a href="detox.html">Detox</a>
    <a href="shopping.html">Shopping</a>
    <a href="cholesterol.html">Cholesterol</a>
    <a href="plantpoints.html">Plant Points</a>
</div>

<h1>📷 Scan Food</h1>

<div id="dailyCounter">
    Today: <span id="dailyCalories">0</span> / <span id="calorieGoal">2000</span> kcal
</div>

<button class="scan-btn" onclick="changeGoal()">Change Calorie Goal</button>

<video id="cameraPreview" autoplay></video>

<button class="scan-btn" onclick="startLiveScan()">Start Live Camera</button>
<button class="scan-btn" onclick="takePhoto()">Take Photo</button>
<button class="scan-btn" onclick="document.getElementById('uploadInput').click()">Upload Photo</button>

<input type="file" id="uploadInput" accept="image/*" style="display:none" onchange="handleUpload(event)">

<!-- NUTRITION CARD -->
<div id="resultCard" class="nutrition-card">
    <div class="card-header">
        <img id="productImage" class="product-image" src="" alt="Food Image">
        <div class="cal-box">
            <span id="calNumber">0</span>
            <small>kcal / 100g</small>
        </div>
    </div>

    <!-- ALTERNATIVE BOX -->
    <div id="alternativeBox" style="display:none; margin-top:20px;">
        <h3 style="color:#42a5f5;">Better Alternative</h3>
        <img id="altImage" src="" style="width:100%; border-radius:12px; margin-bottom:10px;">
        <p id="altText" style="font-size:16px; line-height:1.4;"></p>
    </div>

    <h2 id="foodName" class="food-title"></h2>
</div>

<!-- Healthy Score -->
<div class="health-row">
    <div id="healthGauge" class="health-gauge">0</div>
    <div class="health-labels">
        <div><strong>Healthy score</strong> (0–100)</div>
        <div>Green = better choice</div>
    </div>
</div>

<!-- Nutrition Table -->
<div class="nutri-table">
    <div><strong>Fat</strong><span id="fat"></span> <span id="fatLight" class="traffic"></span></div>
    <div><strong>Sugar</strong><span id="sugar"></span> <span id="sugarLight" class="traffic"></span></div>
    <div><strong>Salt</strong><span id="salt"></span> <span id="saltLight" class="traffic"></span></div>
</div>

<!-- Macro Bars -->
<div class="macro-section">
    <div class="macro-row">
        <div class="macro-label">Protein</div>
        <div class="macro-bar"><div id="macroProtein" class="macro-fill macro-protein"></div></div>
    </div>
    <div class="macro-row">
        <div class="macro-label">Carbs</div>
        <div class="macro-bar"><div id="macroCarbs" class="macro-fill macro-carbs"></div></div>
    </div>
    <div class="macro-row">
        <div class="macro-label">Fat</div>
        <div class="macro-bar"><div id="macroFat" class="macro-fill macro-fat"></div></div>
    </div>
</div>

<p class="rating" id="ratingText"></p>
<p id="reasonText" class="reason"></p>
<p id="novaWarning" class="reason"></p>
<p id="additivesWarning" class="reason"></p>
<p id="betterAlt" class="reason"></p>

<button class="add-btn" id="addDiaryBtn">Add to Diary</button>

<script>
let dailyCalories = 0;
let lastCalories = 0;

// Load saved goal or default to 2000
let calorieGoal = Number(localStorage.getItem("calorieGoal")) || 2000;
document.getElementById("calorieGoal").textContent = calorieGoal;

/* CHANGE CALORIE GOAL */
function changeGoal() {
    let newGoal = prompt("Enter your new daily calorie goal:");

    if (!newGoal || isNaN(newGoal)) {
        alert("Please enter a valid number.");
        return;
    }

    newGoal = Number(newGoal);
    localStorage.setItem("calorieGoal", newGoal);
    document.getElementById("calorieGoal").textContent = newGoal;

    alert("Goal updated!");
}

/* SAVE TO DIARY */
function saveToDiary(foodName, kcal) {
    let diary = JSON.parse(localStorage.getItem("diary")) || [];

    diary.push({
        name: foodName,
        calories: kcal,
        time: new Date().toLocaleString()
    });

    localStorage.setItem("diary", JSON.stringify(diary));
}

/* FLASH EFFECTS */
function flashRed() {
    document.body.classList.remove("flash-red");
    void document.body.offsetWidth;
    document.body.classList.add("flash-red");
}
function flashGreen() {
    document.body.classList.remove("flash-green");
    void document.body.offsetWidth;
    document.body.classList.add("flash-green");
}

let codeReader = new ZXing.BrowserMultiFormatReader();

/* LIVE CAMERA */
async function startLiveScan() {
    const preview = document.getElementById("cameraPreview");

    try {
        preview.style.display = "block";

        const devices = await ZXing.BrowserMultiFormatReader.listVideoInputDevices();
        const backCamera = devices[devices.length - 1].deviceId;

        codeReader.decodeFromVideoDevice(backCamera, "cameraPreview", (result, err) => {
            if (result) {
                preview.style.borderColor = "#00ff66";
                preview.style.boxShadow = "0 0 20px #00ff66";
                lookupBarcode(result.text);
                codeReader.reset();
            } else {
                preview.style.borderColor = "#ff4444";
                preview.style.boxShadow = "0 0 20px #ff4444";
            }
        });

    } catch (err) {
        alert("Live camera only works when the app is online (HTTPS).");
    }
}

/* TAKE PHOTO */
function takePhoto() {
    const input = document.createElement("input");
    input.type = "file";
    input.accept = "image/*";
    input.capture = "environment";

    input.onchange = async (event) => {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = () => decodeImage(reader.result);
        reader.readAsDataURL(file);
    };

    input.click();
}

/* UPLOAD PHOTO */
function handleUpload(event) {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = () => decodeImage(reader.result);
    reader.readAsDataURL(file);
}

/* ZXING DECODE */
function decodeImage(dataUrl) {
    codeReader.decodeFromImageUrl(dataUrl)
        .then(result => lookupBarcode(result.text))
        .catch(() => alert("No barcode detected."));
}

/* LOOKUP FOOD */
async function lookupBarcode(code) {
    const url = `https://world.openfoodfacts.org/api/v0/product/${code}.json`;

    const response = await fetch(url);
    const data = await response.json();

    if (!data.product) {
        alert("Food not found.");
        return;
    }

    const p = data.product;
    const n = p.nutriments || {};

    const kcal    = n["energy-kcal_100g"] || 0;
    const fat     = n.fat_100g || 0;
    const sugar   = n.sugars_100g || 0;
    const salt    = n.salt_100g || 0;
    const protein = n.proteins_100g || 0;
    const carbs   = n.carbohydrates_100g || 0;

    lastCalories = Number(kcal);

    /* TRAFFIC LIGHTS */
    function trafficLight(value, low, high) {
        if (value > high) return { cls: "red", label: "HIGH 🟥" };
        if (value > low)  return { cls: "orange", label: "MED 🟧" };
        return { cls: "green", label: "LOW 🟩" };
    }

    const fatTL   = trafficLight(fat,   3, 17);
    const sugarTL = trafficLight(sugar, 5, 22);
    const saltTL  = trafficLight(salt,  0.3, 1.5);

    document.getElementById("fatLight").className   = "traffic " + fatTL.cls;
    document.getElementById("sugarLight").className = "traffic " + sugarTL.cls;
    document.getElementById("saltLight").className  = "traffic " + saltTL.cls;

    document.getElementById("fatLight").textContent   = fatTL.label;
    document.getElementById("sugarLight").textContent = sugarTL.label;
    document.getElementById("saltLight").textContent  = saltTL.label;

    /* FILL CARD */
    document.getElementById("foodName").textContent = p.product_name || "Unknown";
    document.getElementById("calNumber").textContent = kcal;
    document.getElementById("fat").textContent = fat + " g";
    document.getElementById("sugar").textContent = sugar + " g";
    document.getElementById("salt").textContent = salt + " g";

    document.getElementById("productImage").src =
        p.image_front_small_url || p.image_front_url || "https://via.placeholder.com/120";

    /* HEALTH SCORE */
    let score = 50;
    const grade = p.nutriscore_grade;

    if (grade === "a") score = 90;
    else if (grade === "b") score = 75;
    else if (grade === "c") score = 60;
    else if (grade === "d") score = 40;
    else if (grade === "e") score = 20;

    const gauge = document.getElementById("healthGauge");
    gauge.textContent = score;

    let color = "#4caf50";
    if (score < 50) color = "#ef5350";
    else if (score < 70) color = "#ffca28";

    gauge.style.borderColor = color;
    gauge.style.boxShadow = "0 0 12px " + color + "aa";

    /* MACRO BARS */
    const total = protein + carbs + fat || 1;
    document.getElementById("macroProtein").style.width = (protein / total * 100) + "%";
    document.getElementById("macroCarbs").style.width   = (carbs   / total * 100) + "%";
    document.getElementById("macroFat").style.width     = (fat     / total * 100) + "%";

    /* RATING */
    let rating = "ok";
    let ratingText = "OK choice";
    let reason = "";

    if (fat > 30 || sugar > 15 || salt > 1 || kcal > 400) {
        flashRed();
        rating = "bad";
        ratingText = "Not a healthy choice.";

        if (fat > 30) reason += "Extremely high in fat. ";
        if ((n["saturated-fat_100g"] || 0) > 5) reason += "High in saturated fat. ";
        if (sugar > 15) reason += "High in sugar. ";
        if (salt > 1) reason += "High in salt. ";
        if (kcal > 400) reason += "Very high in calories. ";
    } else if (grade === "a" || grade === "b") {
        flashGreen();
        rating = "good";
        ratingText = "Good choice!";
        reason = "Low in unhealthy nutrients.";
    } else {
        rating = "ok";
        ratingText = "Moderate choice.";
        if (!reason) reason = "Acceptable in moderation. Watch portion size.";
    }

    document.getElementById("ratingText").textContent = ratingText;
    document.getElementById("ratingText").className = "rating " + rating;
    document.getElementById("reasonText").textContent = reason;

    /* NOVA */
    const nova = p.nova_group || 0;
    const novaEl = document.getElementById("novaWarning");

    if (nova === 4) novaEl.textContent = "Ultra‑processed food (NOVA 4).";
    else if (nova === 3) novaEl.textContent = "Processed food (NOVA 3).";
    else if (nova === 2) novaEl.textContent = "Processed culinary ingredient (NOVA 2).";
    else if (nova === 1) novaEl.textContent = "Unprocessed or minimally processed (NOVA 1).";
    else novaEl.textContent = "NOVA group: not available.";

    /* ADDITIVES */
    let additives = p.additives_tags || [];
    let eList = additives
        .filter(a => a.startsWith("en:"))
        .map(a => a.replace("en:", "").toUpperCase());

    if (eList.length > 0) {
        document.getElementById("additivesWarning").textContent =
            "Contains additives: " + eList.join(", ");
    } else {
        document.getElementById("additivesWarning").textContent =
            "No additives listed or not available.";
    }

    /* BETTER ALTERNATIVES */
let alt = "";
if (nova === 4) alt += "Try less processed alternatives. ";
if (fat > 30)   alt += "Choose lighter spreads or low‑fat sauces. ";
if (sugar > 15) alt += "Try low‑sugar versions. ";
if (salt > 1)   alt += "Look for low‑salt options. ";

if (!alt) {
    alt = "This food is acceptable in moderation. Prefer fresh, minimally processed options when possible.";
}

document.getElementById("betterAlt").textContent = alt;

document.getElementById("resultCard").style.display = "block";

// Show alternative suggestion
showAlternative(p.product_name, p);
}

/* ADD TO DIARY */
document.getElementById("addDiaryBtn").addEventListener("click", () => {
    dailyCalories += lastCalories;
    document.getElementById("dailyCalories").textContent = Math.round(dailyCalories);

    const foodName = document.getElementById("foodName").textContent;
    saveToDiary(foodName, lastCalories);

    alert("Added to diary!");
});

/* ALTERNATIVE SYSTEM — WORKS EVEN WHEN NAME IS EMPTY */
function showAlternative(productName, productData) {
    let altImage = document.getElementById("altImage");
    let altText = document.getElementById("altText");
    let box = document.getElementById("alternativeBox");

    let name = (productName || "").toLowerCase();
    const categories = (productData.categories || "").toLowerCase();
    const ingredients = (productData.ingredients_text || "").toLowerCase();

    function has(text, words) {
        return words.some(w => text.includes(w));
    }

    if (
        has(name, ["crisp", "chip", "snack", "potato", "walkers", "lays", "doritos"]) ||
        has(categories, ["crisps", "chips", "snack", "potato"]) ||
        has(ingredients, ["potato", "sunflower oil"])
    ) {
        altImage.src = "https://images.unsplash.com/photo-1603048297172-c92544798e84?auto=format&fit=crop&w=800&q=80";
        altText.innerText = "Swap crisps for a handful of nuts. Healthy fats improve cholesterol and keep you full longer.";
    }
    else if (
        has(name, ["cheese", "cheddar", "mozzarella", "emmental"]) ||
        has(categories, ["cheese"]) ||
        has(ingredients, ["milk", "rennet"])
    ) {
        altImage.src = "https://images.unsplash.com/photo-1514996937319-344454492b37?auto=format&fit=crop&w=800&q=80";
        altText.innerText = "Try low‑fat yogurt instead of cheese. It reduces saturated fat intake and supports heart health.";
    }
    else if (
        has(name, ["bread", "toast", "baguette", "roll"]) ||
        has(categories, ["bread"]) ||
        has(ingredients, ["wheat flour"])
    ) {
        altImage.src = "https://images.unsplash.com/photo-1585238342028-4c4e1f3c1f1c?auto=format&fit=crop&w=800&q=80";
        altText.innerText = "Choose whole grain bread instead of white bread. More fibre helps lower cholesterol naturally.";
    }
    else if (
        has(name, ["butter", "spread", "margarine"]) ||
        has(categories, ["butter"]) ||
        has(ingredients, ["cream", "milkfat"])
    ) {
        altImage.src = "https://images.unsplash.com/photo-1508061253366-f7da158b6d46?auto=format&fit=crop&w=800&q=80";
        altText.innerText = "Try extra virgin olive oil instead of butter. It reduces LDL cholesterol and supports heart health.";
    }
    else if (
        has(name, ["chocolate", "cocoa", "choc"]) ||
        has(categories, ["chocolate"]) ||
        has(ingredients, ["cocoa", "cocoa butter"])
    ) {
        altImage.src = "https://images.unsplash.com/photo-1499636136210-6f4ee915583e?auto=format&fit=crop&w=800&q=80";
        altText.innerText = "Choose dark chocolate (70%+). It contains antioxidants and less sugar than milk chocolate.";
    }
    else {
        altImage.src = "https://images.unsplash.com/photo-1508061253366-f7da158b6d46?auto=format&fit=crop&w=800&q=80";
        altText.innerText = "Choose minimally processed foods, healthy fats, and whole grains to support cholesterol health.";
    }

    box.style.display = "block";
}

</script>
</body>
</html>

